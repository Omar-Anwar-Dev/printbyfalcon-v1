# Production environment — on the VPS, copy to .env.production (never commit real secrets)
NODE_ENV=production
APP_URL=https://printbyfalcon.com
AUTH_SECRET=
AUTH_TRUST_HOST=true

# Password MUST match POSTGRES_PASSWORD below and the password inside DATABASE_URL.
# docker-compose.prod.yml reads POSTGRES_PASSWORD as a separate top-level var
# to configure the postgres container. Keep the three references in sync when rotating.
POSTGRES_PASSWORD=CHANGEME
DATABASE_URL=postgres://pbf_prod:CHANGEME@postgres:5432/pbf_prod?schema=public

# GlitchTip (ADR-026) — separate DB on the same postgres instance, separate secret.
# If you leave these blank, GlitchTip won't boot; the app itself is unaffected.
GLITCHTIP_DATABASE_URL=postgres://glitchtip:CHANGEME@postgres:5432/glitchtip?schema=public
GLITCHTIP_SECRET_KEY=

OWNER_EMAIL=support@printbyfalcon.com
# seeded on first boot only; immediately prompts a password reset on first login
OWNER_TEMP_PASSWORD=CHANGEME-ROTATE-IMMEDIATELY

# WhatsApp transport — Whats360 per ADR-033
WHATS360_TOKEN=
WHATS360_INSTANCE_ID=
WHATS360_WEBHOOK_SECRET=
WHATS360_BASE_URL=https://whats360.live
# sandbox off in prod (real sends); flip to true only for emergency debugging
WHATS360_SANDBOX=false
# flip both to false once the Whats360 device is confirmed connected and a test OTP lands
OTP_DEV_MODE=false
NOTIFICATIONS_DEV_MODE=false

# Sales team manual WhatsApp number (Feature 9 — must differ from the Whats360 device number)
SALES_TEAM_WHATSAPP=+201116527773

SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=support@printbyfalcon.com
SMTP_PASS=
SMTP_FROM_EMAIL=support@printbyfalcon.com
SMTP_FROM_NAME="Print By Falcon"

# Paymob production creds — request fresh keys from Paymob; do NOT reuse sandbox.
# Per ADR-024 Paymob is the single payments vendor. Per ADR-025 Fawry is via the Paymob Accept sub-integration.
PAYMOB_API_KEY=
PAYMOB_INTEGRATION_ID_CARD=
PAYMOB_INTEGRATION_ID_FAWRY=
PAYMOB_HMAC_SECRET=
PAYMOB_IFRAME_ID=

SENTRY_DSN=
SENTRY_ENVIRONMENT=production

STORAGE_ROOT=/storage
LOG_LEVEL=INFO
LOG_PRETTY=false

WORKER_ENABLED=true
WORKER_CONCURRENCY=10
