# Production environment — on the VPS, copy to .env.production (never commit real secrets)
NODE_ENV=production
APP_URL=https://printbyfalcon.com
AUTH_SECRET=
AUTH_TRUST_HOST=true

# Password MUST match POSTGRES_PASSWORD below and the password inside DATABASE_URL.
# docker-compose.prod.yml reads POSTGRES_PASSWORD as a separate top-level var
# to configure the postgres container. Keep the three references in sync when rotating.
POSTGRES_PASSWORD=CHANGEME
DATABASE_URL=postgres://pbf_prod:CHANGEME@postgres:5432/pbf_prod?schema=public

# GlitchTip (ADR-026) — separate DB on the same postgres instance, separate secret.
# If you leave these blank, GlitchTip won't boot; the app itself is unaffected.
GLITCHTIP_DATABASE_URL=postgres://glitchtip:CHANGEME@postgres:5432/glitchtip?schema=public
GLITCHTIP_SECRET_KEY=

OWNER_EMAIL=support@printbyfalcon.com
# seeded on first boot only; immediately prompts a password reset on first login
OWNER_TEMP_PASSWORD=CHANGEME-ROTATE-IMMEDIATELY

# WhatsApp transport — Whats360 per ADR-033
WHATS360_TOKEN=
WHATS360_INSTANCE_ID=
WHATS360_WEBHOOK_SECRET=
WHATS360_BASE_URL=https://whats360.live
# sandbox off in prod (real sends); flip to true only for emergency debugging
WHATS360_SANDBOX=false
# flip both to false once the Whats360 device is confirmed connected and a test OTP lands
OTP_DEV_MODE=false
NOTIFICATIONS_DEV_MODE=false

# Sales team manual WhatsApp number (Feature 9 — must differ from the Whats360 device number)
SALES_TEAM_WHATSAPP=+201116527773

SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=support@printbyfalcon.com
SMTP_PASS=
SMTP_FROM_EMAIL=support@printbyfalcon.com
SMTP_FROM_NAME="Print By Falcon"

# Paymob production creds — Sprint 11.6 Unified Checkout (Intention API).
# Request fresh keys from Paymob dashboard → API Keys; do NOT reuse sandbox.
# Per ADR-024 Paymob is the single payments vendor. Card / wallet / Fawry are
# all surfaced inside the unified Paymob page when their integration IDs are
# set; only PAYMOB_INTEGRATION_ID_CARD is required.
PAYMOB_PUBLIC_KEY=
PAYMOB_SECRET_KEY=
PAYMOB_INTEGRATION_ID_CARD=
PAYMOB_HMAC_SECRET=
# Optional — only set when the matching integrations exist in Paymob dashboard.
PAYMOB_INTEGRATION_ID_WALLET=
PAYMOB_INTEGRATION_ID_FAWRY=

# TEST-mode parallels — read at runtime when admin flips
# /admin/settings/payment-methods → mode = TEST. Lets owners test new keys
# without redeploying. Leave blank if not in use.
PAYMOB_PUBLIC_KEY_TEST=
PAYMOB_SECRET_KEY_TEST=
PAYMOB_INTEGRATION_ID_CARD_TEST=
PAYMOB_INTEGRATION_ID_WALLET_TEST=
PAYMOB_INTEGRATION_ID_FAWRY_TEST=
PAYMOB_HMAC_SECRET_TEST=

# ADR-064 — M1 launches COD-only because Paymob merchant approval is still in
# review. Set this to `false` for the COD-only soft launch; flip to `true` (or
# remove the line) once the live PAYMOB_* keys above are populated and a real
# test card has been verified end-to-end on staging.
# Default behavior when the var is absent is `enabled` — explicit `=false` is
# the opt-out. When `false`, env-check stops requiring the PAYMOB_* keys above
# and the customer-facing checkout hides the online-payment radio.
PAYMENTS_PAYMOB_ENABLED=false

SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# Cloudflare Web Analytics (ADR-073) — privacy-first traffic stats. Token
# from Cloudflare dashboard → Analytics & Logs → Web Analytics.
CLOUDFLARE_WEB_ANALYTICS_TOKEN=

# Meta Pixel + Conversions API (Sprint 15, ADR-074). Pixel ID is
# browser-exposed by design. CAPI access token is server-only — never
# prefix with NEXT_PUBLIC_. Both empty = tracking silently disabled.
NEXT_PUBLIC_META_PIXEL_ID=
META_CAPI_ACCESS_TOKEN=
# Optional — populate temporarily to route events into Events Manager
# Test Events tab (won't pollute production data); unset for live launch.
META_CAPI_TEST_EVENT_CODE=

STORAGE_ROOT=/storage
LOG_LEVEL=INFO
LOG_PRETTY=false

WORKER_ENABLED=true
WORKER_CONCURRENCY=10
