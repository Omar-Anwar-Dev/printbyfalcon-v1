# Staging environment — separate database, sandbox merchant credentials
NODE_ENV=production
APP_URL=https://staging.printbyfalcon.com
AUTH_SECRET=
AUTH_TRUST_HOST=true

# Password MUST match POSTGRES_PASSWORD below and the password inside DATABASE_URL.
# docker-compose.staging.yml reads POSTGRES_PASSWORD as a separate top-level var
# to configure the postgres container — missing it yields blank-password DB user
# + auth-fail errors from the app. Keep the three references in sync when rotating.
POSTGRES_PASSWORD=CHANGEME
DATABASE_URL=postgres://pbf_staging:CHANGEME@postgres-staging:5432/pbf_staging?schema=public

OWNER_EMAIL=support@printbyfalcon.com
OWNER_TEMP_PASSWORD=staging-temp-reset-me

# WhatsApp transport — Whats360 per ADR-033
WHATS360_TOKEN=
WHATS360_INSTANCE_ID=
WHATS360_WEBHOOK_SECRET=
WHATS360_BASE_URL=https://whats360.live
# Keep sandbox=true on staging to avoid billing real sends during QA
WHATS360_SANDBOX=true
# Staging defaults to dev-mode both until the owner flips them to validate real sends
OTP_DEV_MODE=true
NOTIFICATIONS_DEV_MODE=true

# Sales team manual WhatsApp number (Feature 9 — must differ from the Whats360 device number)
SALES_TEAM_WHATSAPP=+201116527773

SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=support@printbyfalcon.com
SMTP_PASS=
SMTP_FROM_EMAIL=staging@printbyfalcon.com
SMTP_FROM_NAME="Print By Falcon [STAGING]"

# Paymob sandbox creds — see ADR-024 (single payments vendor) + ADR-025 (Fawry via Paymob Accept sub-integration)
PAYMOB_API_KEY=
PAYMOB_INTEGRATION_ID_CARD=
PAYMOB_INTEGRATION_ID_FAWRY=
PAYMOB_HMAC_SECRET=
PAYMOB_IFRAME_ID=

# ADR-064 — staging keeps Paymob enabled (sandbox) so the gateway is exercisable
# in QA. Flip to `false` to mirror the M1 production COD-only posture for
# staging dress rehearsals. Default = enabled when the var is absent.
PAYMENTS_PAYMOB_ENABLED=true

SENTRY_DSN=
SENTRY_ENVIRONMENT=staging

STORAGE_ROOT=/storage
LOG_LEVEL=DEBUG
LOG_PRETTY=false

WORKER_ENABLED=true
WORKER_CONCURRENCY=3
