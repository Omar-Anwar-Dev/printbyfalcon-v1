# ---- Application ----
NODE_ENV=development
APP_URL=http://localhost:3000
# used for Auth.js signing; generate with: openssl rand -base64 32
AUTH_SECRET=replace-with-openssl-rand-base64-32
# host(s) the app trusts; comma-separated; prod sets to printbyfalcon.com
AUTH_TRUST_HOST=true

# ---- Database ----
# format: postgres://USER:PASS@HOST:PORT/DBNAME?schema=public
DATABASE_URL=postgres://pbf:pbf@localhost:5432/pbf_dev?schema=public

# ---- Owner admin seed (first boot only; prompts password reset on first login) ----
OWNER_EMAIL=support@printbyfalcon.com
OWNER_TEMP_PASSWORD=change-me-on-first-login

# ---- WhatsApp transport — Whats360 (ADR-033; replaces Meta Cloud API) ----
# Token + instance_id come from the whats360.live dashboard after scanning
# the store's device phone via /api/v1/instances/qr-page. Device MUST be a
# different physical number from SALES_TEAM_WHATSAPP.
WHATS360_TOKEN=
WHATS360_INSTANCE_ID=
# Shared secret configured in Whats360's custom webhook as the "X-Webhook-Token"
# header value; verified at POST /api/webhooks/whats360.
WHATS360_WEBHOOK_SECRET=
# Optional overrides (defaults shown)
WHATS360_BASE_URL=https://whats360.live
# Set to "true" to append &sandbox=true on every send (exercises API, no billing)
WHATS360_SANDBOX=false
# Set to "true" in development to skip the HTTP call and log OTP code to server console
OTP_DEV_MODE=true
# Set to "true" to log all non-OTP WhatsApp sends instead of hitting Whats360
NOTIFICATIONS_DEV_MODE=true

# Sales team manual WhatsApp number (Feature 9 — "Chat with us" floating button).
# E.164 format. MUST be a different physical number than the Whats360 device.
SALES_TEAM_WHATSAPP=+201116527773

# ---- Hostinger SMTP ----
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=support@printbyfalcon.com
SMTP_PASS=replace-with-hostinger-smtp-password
SMTP_FROM_EMAIL=support@printbyfalcon.com
SMTP_FROM_NAME="Print By Falcon"

# ---- Paymob (Sprint 4 for CARD; Sprint 9 surfaces the FAWRY sub-integration) ----
# Per ADR-024 Paymob is the single payments vendor. Per ADR-025 Fawry pay-at-outlet
# is provided via Paymob Accept's sub-integration (NOT a direct Fawry merchant).
PAYMOB_API_KEY=
PAYMOB_INTEGRATION_ID_CARD=
PAYMOB_INTEGRATION_ID_FAWRY=
PAYMOB_HMAC_SECRET=
PAYMOB_IFRAME_ID=

# ---- Error tracking (GlitchTip) ----
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# ---- Storage ----
# local filesystem root for product images + invoices; mounted as /storage in Docker
STORAGE_ROOT=./storage

# ---- Logging ----
# Use uppercase (INFO/DEBUG/WARN/ERROR) — Pino accepts both cases, but containerized
# Python tools (e.g. GlitchTip) inheriting this var via env_file require uppercase.
LOG_LEVEL=INFO
LOG_PRETTY=true

# ---- Worker ----
WORKER_ENABLED=true
WORKER_CONCURRENCY=5
