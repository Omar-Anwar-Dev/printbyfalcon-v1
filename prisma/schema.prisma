// Print By Falcon — Prisma schema.
// Sprint 1: identity, access, rate limiting, audit log, settings, OTP/password-reset,
// admin invites.
// Sprint 2: catalog (brands, categories with unlimited nesting per ADR-027, products,
// product images, printer models, product↔printer compatibility).
// Later sprints will add cart, orders, inventory, invoicing, notifications.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -------------------------------------------------------------------------
// Identity & Access
// -------------------------------------------------------------------------

enum UserType {
  B2C
  B2B
  ADMIN
}

enum AdminRole {
  OWNER
  OPS
  SALES_REP
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DEACTIVATED
}

enum Locale {
  AR
  EN
}

model User {
  id                   String     @id @default(cuid())
  type                 UserType
  name                 String
  phone                String?    @unique
  email                String?    @unique
  passwordHash         String?    // null for B2C (OTP-only)
  adminRole            AdminRole? // only for type=ADMIN
  status               UserStatus @default(ACTIVE)
  languagePref         Locale     @default(AR)
  mustChangePassword   Boolean    @default(false)
  lastLoginAt          DateTime?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  sessions       Session[]
  passwordResets PasswordReset[]
  auditLogs      AuditLog[]      @relation("ActorAuditLogs")

  @@index([type, status])
}

model Session {
  id           String   @id @default(cuid())
  token        String   @unique // hashed; the raw token lives only in the cookie
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceLabel  String?
  ipAddress    String?
  userAgent    String?
  expiresAt    DateTime
  lastSeenAt   DateTime @default(now())
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model WhatsAppOtp {
  id         String   @id @default(cuid())
  phone      String
  codeHash   String   // SHA-256 of the 6-digit code
  attempts   Int      @default(0)
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime @default(now())

  @@index([phone, createdAt])
}

model PasswordReset {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String   @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime @default(now())

  @@index([userId])
}

model AdminInvite {
  id          String    @id @default(cuid())
  email       String    @unique
  role        AdminRole
  invitedById String
  tokenHash   String    @unique
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([invitedById])
}

// -------------------------------------------------------------------------
// Rate limiting — DB-backed sliding window (Sprint 1)
// -------------------------------------------------------------------------

model RateLimit {
  id          String   @id @default(cuid())
  // composite key, e.g. "otp-request:+201116527773" or "b2b-login:user@x.com"
  key         String
  windowStart DateTime
  count       Int      @default(1)
  createdAt   DateTime @default(now())

  @@unique([key, windowStart])
  @@index([key, windowStart])
}

// -------------------------------------------------------------------------
// Settings — flexible KV, JSON-valued
// -------------------------------------------------------------------------

model Setting {
  key         String   @id
  value       Json
  updatedBy   String?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
}

// -------------------------------------------------------------------------
// Catalog (Sprint 2) — brands, categories, products, images, printer models,
// and product↔printer compatibility. See docs/architecture.md §5.2 and
// docs/decisions.md ADR-027 (unlimited category nesting).
// -------------------------------------------------------------------------

enum Authenticity {
  GENUINE
  COMPATIBLE
}

// Shared active/archived status for catalog entities. Archived rows stay in
// the DB (preserve audit + existing references) but are hidden from the
// public storefront. Hard delete only allowed when no dependent rows exist.
enum CatalogStatus {
  ACTIVE
  ARCHIVED
}

model Brand {
  id        String        @id @default(cuid())
  nameAr    String
  nameEn    String
  slug      String        @unique
  status    CatalogStatus @default(ACTIVE)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  products      Product[]
  printerModels PrinterModel[]

  @@index([status])
}

model Category {
  id        String        @id @default(cuid())
  parentId  String?
  parent    Category?     @relation("CategoryTree", fields: [parentId], references: [id], onDelete: Restrict)
  children  Category[]    @relation("CategoryTree")
  nameAr    String
  nameEn    String
  slug      String        @unique
  position  Int           @default(0)
  status    CatalogStatus @default(ACTIVE)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  products Product[]

  @@index([parentId, position])
  @@index([status])
}

model Product {
  id            String        @id @default(cuid())
  sku           String        @unique
  brandId       String
  brand         Brand         @relation(fields: [brandId], references: [id], onDelete: Restrict)
  categoryId    String
  category      Category      @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  slug          String        @unique
  nameAr        String
  nameEn        String
  descriptionAr String        @db.Text
  descriptionEn String        @db.Text
  // free-form key/value bag: `{ "printSpeed": "35 ppm", "pageYield": 3000 }`.
  // Shape isn't enforced at DB level; admin UI provides a key/value editor.
  specs         Json          @default("{}")
  basePriceEgp  Decimal       @db.Decimal(10, 2)
  vatExempt     Boolean       @default(false)
  authenticity  Authenticity  @default(GENUINE)
  status        CatalogStatus @default(ACTIVE)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  images          ProductImage[]
  compatibilities ProductCompatibility[]

  @@index([brandId])
  @@index([categoryId])
  @@index([status])
  @@index([authenticity])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  // canonical filename stem (cuid); on disk three variants exist:
  //   /storage/products/{productId}/thumb-{filename}.webp     (200px)
  //   /storage/products/{productId}/medium-{filename}.webp    (800px)
  //   /storage/products/{productId}/original-{filename}.webp  (max 1600px)
  filename  String
  position  Int      @default(0)
  altAr     String?
  altEn     String?
  createdAt DateTime @default(now())

  @@index([productId, position])
}

model PrinterModel {
  id        String        @id @default(cuid())
  brandId   String
  brand     Brand         @relation(fields: [brandId], references: [id], onDelete: Restrict)
  modelName String
  slug      String        @unique
  status    CatalogStatus @default(ACTIVE)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  compatibilities ProductCompatibility[]

  @@unique([brandId, modelName])
  @@index([status])
}

model ProductCompatibility {
  productId      String
  product        Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  printerModelId String
  printerModel   PrinterModel @relation(fields: [printerModelId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@id([productId, printerModelId])
  @@index([printerModelId])
}

// -------------------------------------------------------------------------
// Audit log — append-only
// -------------------------------------------------------------------------

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actor      User?    @relation("ActorAuditLogs", fields: [actorId], references: [id], onDelete: SetNull)
  action     String   // e.g., "auth.login", "user.create", "order.status_change"
  entityType String?  // e.g., "User", "Order"
  entityId   String?
  before     Json?
  after      Json?
  note       String?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([action, createdAt])
  @@index([entityType, entityId])
  @@index([actorId, createdAt])
}
