// Print By Falcon — Prisma schema.
// Sprint 1: identity, access, rate limiting, audit log, settings, OTP/password-reset,
// admin invites.
// Sprint 2: catalog (brands, categories with unlimited nesting per ADR-027, products,
// product images, printer models, product↔printer compatibility).
// Sprint 3: FTS searchVector on Product (see lib/catalog/search-vector.ts, ADR-029).
// Sprint 4: address, cart, minimal inventory + reservations + movements, order
// + order items + status events, payment plumbing (Paymob card + COD per ADR-030;
// Fawry via Paymob sub-integration deferred to Sprint 9 per ADR-025).

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -------------------------------------------------------------------------
// Identity & Access
// -------------------------------------------------------------------------

enum UserType {
  B2C
  B2B
  ADMIN
}

enum AdminRole {
  OWNER
  OPS
  SALES_REP
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DEACTIVATED
}

enum Locale {
  AR
  EN
}

model User {
  id                 String     @id @default(cuid())
  type               UserType
  name               String
  phone              String?    @unique
  email              String?    @unique
  passwordHash       String? // null for B2C (OTP-only)
  adminRole          AdminRole? // only for type=ADMIN
  status             UserStatus @default(ACTIVE)
  languagePref       Locale     @default(AR)
  mustChangePassword Boolean    @default(false)
  lastLoginAt        DateTime?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  sessions       Session[]
  passwordResets PasswordReset[]
  auditLogs      AuditLog[]      @relation("ActorAuditLogs")
  addresses      Address[]       @relation("UserAddresses")
  cart           Cart?           @relation("UserCart")
  orders         Order[]         @relation("UserOrders")
  notifications  Notification[]  @relation("UserNotifications")
  authoredReturns Return[]       @relation("ReturnAuthor")
  generatedInvoices Invoice[]    @relation("InvoiceAuthor")

  @@index([type, status])
}

model Session {
  id          String   @id @default(cuid())
  token       String   @unique // hashed; the raw token lives only in the cookie
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceLabel String?
  ipAddress   String?
  userAgent   String?
  expiresAt   DateTime
  lastSeenAt  DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model WhatsAppOtp {
  id        String    @id @default(cuid())
  phone     String
  codeHash  String // SHA-256 of the 6-digit code
  attempts  Int       @default(0)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([phone, createdAt])
}

model PasswordReset {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model AdminInvite {
  id          String    @id @default(cuid())
  email       String    @unique
  role        AdminRole
  invitedById String
  tokenHash   String    @unique
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([invitedById])
}

// -------------------------------------------------------------------------
// Rate limiting — DB-backed sliding window (Sprint 1)
// -------------------------------------------------------------------------

model RateLimit {
  id          String   @id @default(cuid())
  // composite key, e.g. "otp-request:+201116527773" or "b2b-login:user@x.com"
  key         String
  windowStart DateTime
  count       Int      @default(1)
  createdAt   DateTime @default(now())

  @@unique([key, windowStart])
  @@index([key, windowStart])
}

// -------------------------------------------------------------------------
// Settings — flexible KV, JSON-valued
// -------------------------------------------------------------------------

model Setting {
  key       String   @id
  value     Json
  updatedBy String?
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

// -------------------------------------------------------------------------
// Catalog (Sprint 2) — brands, categories, products, images, printer models,
// and product↔printer compatibility. See docs/architecture.md §5.2 and
// docs/decisions.md ADR-027 (unlimited category nesting).
// -------------------------------------------------------------------------

enum Authenticity {
  GENUINE
  COMPATIBLE
}

// Shared active/archived status for catalog entities. Archived rows stay in
// the DB (preserve audit + existing references) but are hidden from the
// public storefront. Hard delete only allowed when no dependent rows exist.
enum CatalogStatus {
  ACTIVE
  ARCHIVED
}

model Brand {
  id        String        @id @default(cuid())
  nameAr    String
  nameEn    String
  slug      String        @unique
  status    CatalogStatus @default(ACTIVE)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  products      Product[]
  printerModels PrinterModel[]

  @@index([status])
}

model Category {
  id        String        @id @default(cuid())
  parentId  String?
  parent    Category?     @relation("CategoryTree", fields: [parentId], references: [id], onDelete: Restrict)
  children  Category[]    @relation("CategoryTree")
  nameAr    String
  nameEn    String
  slug      String        @unique
  position  Int           @default(0)
  status    CatalogStatus @default(ACTIVE)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  products Product[]

  @@index([parentId, position])
  @@index([status])
}

model Product {
  id            String                   @id @default(cuid())
  sku           String                   @unique
  brandId       String
  brand         Brand                    @relation(fields: [brandId], references: [id], onDelete: Restrict)
  categoryId    String
  category      Category                 @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  slug          String                   @unique
  nameAr        String
  nameEn        String
  descriptionAr String                   @db.Text
  descriptionEn String                   @db.Text
  // free-form key/value bag: `{ "printSpeed": "35 ppm", "pageYield": 3000 }`.
  // Shape isn't enforced at DB level; admin UI provides a key/value editor.
  specs         Json                     @default("{}")
  basePriceEgp  Decimal                  @db.Decimal(10, 2)
  vatExempt     Boolean                  @default(false)
  authenticity  Authenticity             @default(GENUINE)
  status        CatalogStatus            @default(ACTIVE)
  // Full-text search vector — populated by `lib/catalog/search-vector.ts` on
  // product create/update + brand rename. GIN index added by scripts/post-push.ts
  // (db push doesn't emit indexes on Unsupported types).
  searchVector  Unsupported("tsvector")?
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt

  images                ProductImage[]
  compatibilities       ProductCompatibility[]
  inventory             Inventory?
  inventoryReservations InventoryReservation[]
  inventoryMovements    InventoryMovement[]
  cartItems             CartItem[]
  orderItems            OrderItem[]

  @@index([brandId])
  @@index([categoryId])
  @@index([status])
  @@index([authenticity])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  // canonical filename stem (cuid); on disk three variants exist:
  //   /storage/products/{productId}/thumb-{filename}.webp     (200px)
  //   /storage/products/{productId}/medium-{filename}.webp    (800px)
  //   /storage/products/{productId}/original-{filename}.webp  (max 1600px)
  filename  String
  position  Int      @default(0)
  altAr     String?
  altEn     String?
  createdAt DateTime @default(now())

  @@index([productId, position])
}

model PrinterModel {
  id        String        @id @default(cuid())
  brandId   String
  brand     Brand         @relation(fields: [brandId], references: [id], onDelete: Restrict)
  modelName String
  slug      String        @unique
  status    CatalogStatus @default(ACTIVE)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  compatibilities ProductCompatibility[]

  @@unique([brandId, modelName])
  @@index([status])
}

model ProductCompatibility {
  productId      String
  product        Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  printerModelId String
  printerModel   PrinterModel @relation(fields: [printerModelId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@id([productId, printerModelId])
  @@index([printerModelId])
}

// -------------------------------------------------------------------------
// Geography & shipping (Sprint 4 — Address; ShippingZone / Courier in S5–S9)
// -------------------------------------------------------------------------

/// Egyptian governorates (27). Used on Address.governorate and later on
/// GovernorateZone mapping (Sprint 9). Stored as enum so typos at the UI layer
/// can't leak into the DB.
enum Governorate {
  CAIRO
  GIZA
  QALYUBIA
  ALEXANDRIA
  BEHEIRA
  DAKAHLIA
  DAMIETTA
  GHARBIA
  KAFR_EL_SHEIKH
  MENOUFIA
  SHARQIA
  ISMAILIA
  PORT_SAID
  SUEZ
  NORTH_SINAI
  SOUTH_SINAI
  RED_SEA
  MATRUH
  NEW_VALLEY
  BENI_SUEF
  FAYOUM
  MINYA
  ASYUT
  SOHAG
  QENA
  LUXOR
  ASWAN
}

model Address {
  id            String      @id @default(cuid())
  userId        String?
  user          User?       @relation("UserAddresses", fields: [userId], references: [id], onDelete: Cascade)
  // Recipient info — snapshot to allow guest checkout without a User row.
  recipientName String
  phone         String
  governorate   Governorate
  city          String
  area          String?
  street        String
  building      String?
  apartment     String?
  notes         String?
  isDefault     Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([userId, isDefault])
}

// -------------------------------------------------------------------------
// Cart (Sprint 4 — session-based for guests, user-based for logged-in B2C)
// -------------------------------------------------------------------------

model Cart {
  id         String    @id @default(cuid())
  userId     String?   @unique
  user       User?     @relation("UserCart", fields: [userId], references: [id], onDelete: Cascade)
  sessionKey String?   @unique // for guest carts; migrated to userId on sign-in
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  items CartItem[]
}

model CartItem {
  id                   String   @id @default(cuid())
  cartId               String
  cart                 Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId            String
  product              Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  qty                  Int
  unitPriceEgpSnapshot Decimal  @db.Decimal(10, 2)
  addedAt              DateTime @default(now())

  @@unique([cartId, productId])
  @@index([cartId])
}

// -------------------------------------------------------------------------
// Inventory (Sprint 4 — minimal placeholder; S6 extends with full features)
// -------------------------------------------------------------------------

enum InventoryReservationType {
  CART // 15-min TTL soft hold
  ORDER // firm hold until order terminal state
}

enum InventoryMovementType {
  RECEIVE
  SALE
  ADJUST
  RETURN
  RESERVATION_RELEASE
}

model Inventory {
  productId         String   @id
  product           Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  currentQty        Int      @default(0)
  lowStockThreshold Int?
  updatedAt         DateTime @updatedAt
}

model InventoryReservation {
  id        String                   @id @default(cuid())
  type      InventoryReservationType
  productId String
  product   Product                  @relation(fields: [productId], references: [id], onDelete: Cascade)
  // CART reservations: refId = CartItem.id. ORDER reservations: refId = OrderItem.id.
  refId     String
  qty       Int
  expiresAt DateTime? // null for ORDER-type (until terminal state)
  createdAt DateTime                 @default(now())

  @@index([productId, expiresAt])
  @@index([refId])
  @@index([type, expiresAt])
}

model InventoryMovement {
  id        String                @id @default(cuid())
  productId String
  product   Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  type      InventoryMovementType
  qtyDelta  Int // positive for RECEIVE/RETURN, negative for SALE/ADJUST-down
  reason    String?
  refId     String? // order_id, adjustment_id, etc.
  actorId   String?
  createdAt DateTime              @default(now())

  @@index([productId, createdAt])
}

// -------------------------------------------------------------------------
// Orders (Sprint 4 — B2C happy path; B2B extensions + Company relation in S6+)
// -------------------------------------------------------------------------

enum OrderType {
  B2C
  B2B
}

enum OrderStatus {
  PENDING_CONFIRMATION // B2B Submit-for-Review only
  CONFIRMED
  HANDED_TO_COURIER
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  RETURNED
  DELAYED_OR_ISSUE
}

enum PaymentMethod {
  PAYMOB_CARD
  PAYMOB_FAWRY // Sprint 9 via Paymob sub-integration
  COD
  SUBMIT_FOR_REVIEW // B2B path (S6+)
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  PENDING_ON_DELIVERY // COD: payment taken at delivery
}

model Order {
  id          String    @id @default(cuid())
  /// Human-readable ID: `ORD-YY-DDMM-NNNNN` — daily-reset serial per ADR-019.
  orderNumber String    @unique
  userId      String?
  user        User?     @relation("UserOrders", fields: [userId], references: [id], onDelete: SetNull)
  type        OrderType @default(B2C)

  // Guest-checkout snapshot fields (also populated for logged-in users for stability).
  contactName  String
  contactPhone String
  contactEmail String?

  // Address snapshot — JSON so the order stays legible even if the Address row later changes.
  addressSnapshot Json

  status        OrderStatus   @default(CONFIRMED)
  paymentMethod PaymentMethod
  paymentStatus PaymentStatus @default(PENDING)

  subtotalEgp Decimal @db.Decimal(10, 2)
  shippingEgp Decimal @default(0) @db.Decimal(10, 2)
  discountEgp Decimal @default(0) @db.Decimal(10, 2)
  vatEgp      Decimal @default(0) @db.Decimal(10, 2)
  totalEgp    Decimal @db.Decimal(10, 2)

  // Paymob correlation — populated when paymentMethod is a Paymob flow.
  paymobOrderId       String?
  paymobTransactionId String? @unique

  // Courier handoff — populated when the order transitions to HANDED_TO_COURIER.
  courierId            String?
  courier              Courier?  @relation(fields: [courierId], references: [id], onDelete: SetNull)
  courierPhoneSnapshot String? // snapshot so the customer-facing page survives courier edits
  waybill              String?
  expectedDeliveryDate DateTime?

  internalNotes String?
  customerNotes String?

  // Cancellation request (Sprint 5 S5-D4): customer requests cancel pre-HandedToCourier;
  // admin approves (→ status=CANCELLED + reservation release) or denies (resolution recorded).
  // Null `cancellationRequestedAt` = no request ever. `cancellationResolvedAt` null while pending.
  cancellationRequestedAt     DateTime?
  cancellationReason          String?
  cancellationResolvedAt      DateTime?
  cancellationResolution      CancellationResolution?
  cancellationResolutionNote  String?
  cancellationResolvedById    String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  confirmedAt DateTime?
  deliveredAt DateTime?

  items         OrderItem[]
  statusEvents  OrderStatusEvent[]
  notifications Notification[]
  returns       Return[]
  invoices      Invoice[]

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([paymentMethod, paymentStatus])
  @@index([createdAt])
  @@index([courierId])
  // Fast filter for the admin cancellation queue: pending cancellations
  // (requested but not resolved). `resolvedAt IS NULL AND requestedAt IS NOT NULL`.
  @@index([cancellationRequestedAt, cancellationResolvedAt])
}

enum CancellationResolution {
  APPROVED
  DENIED
}

// ---------------------------------------------------------------------------
// Returns (Sprint 5 S5-D7-T2)
// Customer messages via WhatsApp; admin records a Return row here with the
// decision (per ADR-033 resolution). No self-serve return UI in MVP — the
// admin types it in, picks the refund path, and the Whats360 message to the
// customer goes out via the existing notification pipeline.
// ---------------------------------------------------------------------------

enum RefundDecision {
  PENDING
  APPROVED_CASH
  APPROVED_CARD_MANUAL
  DENIED
}

model Return {
  id                String          @id @default(cuid())
  orderId           String
  order             Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  reason            String
  refundDecision    RefundDecision  @default(PENDING)
  refundAmountEgp   Decimal?        @db.Decimal(10, 2)
  note              String?
  createdById       String?
  createdBy         User?           @relation("ReturnAuthor", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  items             ReturnItem[]

  @@index([orderId])
  @@index([refundDecision, createdAt])
}

model ReturnItem {
  id          String   @id @default(cuid())
  returnId    String
  return      Return   @relation(fields: [returnId], references: [id], onDelete: Cascade)
  orderItemId String
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  qty         Int

  @@index([returnId])
}

model OrderItem {
  id             String   @id @default(cuid())
  orderId        String
  order          Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId      String?
  product        Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  // Snapshots — preserve line-item details even if the product is later edited/archived.
  skuSnapshot    String
  nameArSnapshot String
  nameEnSnapshot String
  qty            Int
  unitPriceEgp   Decimal  @db.Decimal(10, 2)
  lineTotalEgp   Decimal  @db.Decimal(10, 2)
  vatEgp         Decimal  @default(0) @db.Decimal(10, 2)
  createdAt      DateTime @default(now())

  returnItems    ReturnItem[]

  @@index([orderId])
  @@index([productId])
}

model OrderStatusEvent {
  id        String      @id @default(cuid())
  orderId   String
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status    OrderStatus
  note      String?
  actorId   String?
  createdAt DateTime    @default(now())

  @@index([orderId, createdAt])
}

/// Per-day order-serial counter — `ORD-YY-DDMM-NNNNN` daily reset (ADR-019).
/// Row keyed by `YYYYMMDD` int; SERIALIZABLE increment in generateOrderNumber().
model OrderDailySequence {
  id         Int      @id // YYYYMMDD
  lastSerial Int      @default(0)
  updatedAt  DateTime @updatedAt
}

// -------------------------------------------------------------------------
// Couriers — admin-editable partner list used at HANDED_TO_COURIER transition.
// -------------------------------------------------------------------------

model Courier {
  id        String   @id @default(cuid())
  nameAr    String
  nameEn    String
  phone     String? // default contact line (overridable per-order at handoff)
  position  Int      @default(0) // sort order in admin dropdowns
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders Order[]

  @@index([active, position])
}

// -------------------------------------------------------------------------
// Notifications — append-only send log (worker-managed, Whats360 + SMTP).
// -------------------------------------------------------------------------

enum NotificationChannel {
  WHATSAPP
  EMAIL
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

model Notification {
  id                String              @id @default(cuid())
  userId            String?
  user              User?               @relation("UserNotifications", fields: [userId], references: [id], onDelete: SetNull)
  channel           NotificationChannel
  /// Logical template key (e.g. `order.statusChange`, `otp`, `order.confirmed`).
  template          String
  /// Rendered payload at enqueue time — phone/email, body text, subject, etc.
  payload           Json
  relatedOrderId    String?
  relatedOrder      Order?              @relation(fields: [relatedOrderId], references: [id], onDelete: SetNull)
  status            NotificationStatus  @default(PENDING)
  externalMessageId String? // Whats360 id or SMTP message-id
  errorMessage      String?
  createdAt         DateTime            @default(now())
  sentAt            DateTime?

  @@index([status, createdAt])
  @@index([userId, createdAt])
  @@index([relatedOrderId])
}

// -------------------------------------------------------------------------
// Audit log — append-only
// -------------------------------------------------------------------------

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actor      User?    @relation("ActorAuditLogs", fields: [actorId], references: [id], onDelete: SetNull)
  action     String // e.g., "auth.login", "user.create", "order.status_change"
  entityType String? // e.g., "User", "Order"
  entityId   String?
  before     Json?
  after      Json?
  note       String?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([action, createdAt])
  @@index([entityType, entityId])
  @@index([actorId, createdAt])
}

// -------------------------------------------------------------------------
// Invoicing (Sprint 6 — ADR-034).
// Invoices are *metadata rows* only. PDFs are rendered on-demand from the
// immutable Order/OrderItem snapshots; we never write files to disk. Legal
// retention (5 years per ADR-003) is satisfied by the Invoice row + the
// deterministic re-render path in lib/invoices/render.ts.
//
// Numbering (ADR-020): `INV-YY-NNNNNN` gapless annual serial via
// InvoiceAnnualSequence (atomic upsert + RETURNING pattern, identical to
// OrderDailySequence in lib/order/order-number.ts).
// -------------------------------------------------------------------------

model Invoice {
  id              String    @id @default(cuid())
  /// `INV-YY-NNNNNN` — gapless annual serial (ADR-020).
  invoiceNumber   String    @unique
  orderId         String
  order           Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  version         Int       @default(1)
  /// When > 1, this invoice amends a prior version. The chain walks via amendedFromId.
  amendedFromId   String?
  amendedFrom     Invoice?  @relation("InvoiceAmendments", fields: [amendedFromId], references: [id], onDelete: SetNull)
  amendedBy       Invoice[] @relation("InvoiceAmendments")
  amendmentReason String?
  isAmended       Boolean   @default(false)
  generatedById   String?
  generatedBy     User?     @relation("InvoiceAuthor", fields: [generatedById], references: [id], onDelete: SetNull)
  generatedAt     DateTime  @default(now())

  @@index([orderId, version])
  @@index([generatedAt])
}

/// Gapless annual invoice-number counter (ADR-020). Row keyed by YY (e.g., 26).
model InvoiceAnnualSequence {
  year       Int      @id // last two digits of the year, e.g., 26
  lastSerial Int      @default(0)
  updatedAt  DateTime @updatedAt
}
